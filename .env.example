# MRI-LMICs-survey Configuration Template
# Copy this file to '.env' and fill in the values

# --- OpenAlex API (Scientometrics) ---
# To use the 'polite pool' (faster & higher limits), provide a professional email.
# Documentation: https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_MAIL=your-email@example.com

# --- World Bank API (Geographic Equity) ---
# Public API - No key required. This URL is used as the base for income level lookups.
WORLD_BANK_API_URL=https://api.worldbank.org/v2

# --- Data Paths (Relative to project root) ---
DATA_INPUT_PATH=data/data-clean.csv
DATA_CACHE_PATH=data/.cache
OUTPUT_DIR=tables
LOG_DIR=06_processing_outputs
